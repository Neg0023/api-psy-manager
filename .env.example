# ----------------------------------------------------------------------
# Variáveis de ambiente do backend (copie para .env e preencha)
# ----------------------------------------------------------------------

# Banco PostgreSQL (Neon). Formato JDBC:
#   jdbc:postgresql://<host>.neon.tech/<database>?sslmode=require
DATABASE_URL=jdbc:postgresql://<host>.neon.tech/<database>?sslmode=require
DB_USER=postgres
DB_PASSWORD=postgres

# E-mail do único usuário autorizado (psicólogo Admin)
ADMIN_EMAIL=seu-email@gmail.com

# OAuth do Google (Google Cloud Console -> Credentials)
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# Client secret e callback (necessários para a Google Forms API - Etapa 5)
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/integrations/google/callback

# Chave AES em Base64 (32 bytes) para cifrar o refresh token do Google.
# Gere com: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# Origens do frontend liberadas no CORS (lista separada por vírgula).
# Sem curinga "*": a SPA envia credenciais (header Authorization).
# Ex.: http://localhost:5173,https://app.exemplo.com
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
